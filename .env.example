# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no Git

ANTHROPIC_API_KEY=sk-ant-...

# Redis — para persistência do histórico de conversas entre reinicializações
# Railway fornece essa variável automaticamente ao linkar o serviço Redis
REDIS_URL=redis://localhost:6379

# Z-API — Painel → instância → Credenciais
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# Identidade do agente
AGENT_NAME=Lia
BRAND_NAME=AE Alugue Estética

# Especialista humano (recebe notificação quando lead está quente)
SPECIALIST_PHONE=5511999999999
SPECIALIST_NAME=Consultor

# Leads já em atendimento humano — separados por vírgula, sem espaço
# Exemplo: 5511999999999,5521999999999
BLOCKED_PHONES=

# Monitoramento — alerta por email quando Z-API desconectar
# Use uma conta Gmail com App Password (não a senha normal)
# Gerar App Password: myaccount.google.com → Segurança → Senhas de app
ALERT_EMAIL_USER=seuemail@gmail.com
ALERT_EMAIL_PASS=xxxx xxxx xxxx xxxx
ALERT_EMAILS=email1@gmail.com,email2@gmail.com,email3@gmail.com
